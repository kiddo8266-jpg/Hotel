generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("editor")
  createdAt DateTime @default(now())
  posts     BlogPost[]
}

model Apartment {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  priceDuration String @default("per month")
  image       String
  type        String
  bedrooms    Int
  bathrooms   Int
  size        Int
  features    String   // comma-separated fallback/legacy
  amenities   Amenity[]
  createdAt   DateTime @default(now())

  @@index([type])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  image       String
  category    String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   // "image" or "video"
  alt       String
  section   String
  area      String   @default("")  // hotel area the media depicts
  createdAt DateTime @default(now())
}

model SiteSetting {
  id               String @id @default("main")
  hotelName        String @default("NL Josephine's Hotel")
  address          String @default("Seguku, Entebbe Road\\nKampala, Uganda")
  heroTitle        String
  heroSubtitle     String
  heroImage        String
  aboutText        String
  contactPhone     String
  contactEmail     String
  aboutHero        String @default("More Than a Residence.\\nNL Josephine's Hotel.")
  aboutVision      String @default("Born from a desire to blend uncompromising tranquility with modern luxury.")
  aboutStory       String @default("NL Josephine's Hotel & Apt was designed as a retreat from the ordinary. We believe that a home is not just a place, but a feeling—a serene haven where life's best moments unfold.\\n\\nEvery detail, from the grand architecture to the finest interior finishes, has been meticulously curated to foster an environment of peace, security, and absolute comfort for our residents.")
  facebookUrl      String @default("https://facebook.com")
  instagramUrl     String @default("https://instagram.com")
  twitterUrl       String @default("https://twitter.com")
  youtubeUrl       String @default("https://youtube.com")
  tiktokUrl        String @default("https://tiktok.com")
  seoKeywords      String @default("vacation rental, serviced apartments, luxury hotel, Entebbe, Uganda")
  seoDescription   String @default("NL Josephine's Hotel offers uncompromising tranquility with modern luxury in Seguku, Entebbe Road.")
  spiritImage      String @default("https://images.unsplash.com/photo-1582719508461-905c673771fd?q=80&w=2600&auto=format&fit=crop")
  spiritHeading    String @default("The Spirit of NL Josephine's Hotel")
  spiritLabel      String @default("Our Heritage")
  footerBadge      String @default("A Sanctuary")
  footerDescription String @default("Experience quiet luxury and uncompromising comfort. Your serene home away from home in the heart of Seguku.")
  bookingLink      String @default("")
  logoUrl          String @default("")
  logoAlt          String @default("NL Josephine's Hotel Logo")
  journalHeroLabel       String @default("Our Stories")
  journalHeroTitle       String @default("The Journal")
  journalHeroDescription String @default("Stay updated with the latest happenings, exclusive offers, and stories from our sanctuary.")
  aboutHeroImage         String @default("https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&q=80")
  aboutVisionImage1      String @default("https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=80")
  aboutVisionImage2      String @default("https://images.unsplash.com/photo-1512918728675-ed5a9ecdebfd?auto=format&fit=crop&q=80")
  apartmentsHeroImage    String @default("https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&q=80")
  contactHeroImage       String @default("https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80")
  journalHeroImage       String @default("https://images.unsplash.com/photo-1455391704245-2376bb74b358?auto=format&fit=crop&q=80")
  
  // New managed fields for sections
  suitesHeading          String @default("Distinctive Suites")
  suitesDescription      String @default("Our most exclusive accommodations, individually curated to offer exceptional comfort, blending modern aesthetics with thoughtful amenities.")
  amenitiesHeading       String @default("Curated Amenities")
  amenitiesDescription   String @default("We believe true luxury lies in the details. Discover a thoughtful collection of amenities designed to elevate every moment of your stay with us.")
  amenitiesSubtitle      String @default("The Experience")
  experienceTitle        String @default("Everything you need, beautifully anticipated.")
  experienceLabel        String @default("Unparalleled Comfort")
  aboutLeadershipHeading String @default("The People Behind The Haven")
  aboutLeadershipDescription String @default("A dedicated team of professionals committed to delivering an exceptional living experience.")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String?
  image     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model HeroContent {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  mediaUrl  String
  mediaType String   // "image" or "video"
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive])
}

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  status    String   @default("new") // new, read, replied, archived
  createdAt DateTime @default(now())
}

model Amenity {
  id          String   @id @default(cuid())
  iconName    String
  title       String
  description String
  image       String?  @default("")
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  apartments  Apartment[]
}

model NavigationLink {
  id        String   @id @default(cuid())
  label     String
  href      String
  order     Int      @default(0)
  isHeader  Boolean  @default(true)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model JournalMarketingCard {
  id          String   @id @default(cuid())
  tag         String   @default("")
  title       String
  description String
  image       String   @default("")
  buttonLabel String   @default("Send Enquiry")
  subject     String   @default("New Enquiry")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}