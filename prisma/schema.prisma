generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("editor")
  createdAt DateTime @default(now())
  posts     BlogPost[]
}

model Apartment {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  image       String
  type        String
  bedrooms    Int
  bathrooms   Int
  size        Int
  features    String   // comma-separated for simplicity
  createdAt   DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  image       String
  category    String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   // "image" or "video"
  alt       String
  section   String
  area      String   @default("")  // hotel area the media depicts
  createdAt DateTime @default(now())
}

model SiteSetting {
  id               String @id @default("main")
  heroTitle        String
  heroSubtitle     String
  heroImage        String
  aboutText        String
  contactPhone     String
  contactEmail     String
  aboutHero        String @default("More Than a Residence.\\nNL Josephine's Hotel.")
  aboutVision      String @default("Born from a desire to blend uncompromising tranquility with modern luxury.")
  aboutStory       String @default("NL Josephine's Hotel was designed as a retreat from the ordinary. We believe that a home is not just a place, but a feeling—a serene sanctuary where life's best moments unfold.\\n\\nEvery detail, from the grand architecture to the finest interior finishes, has been meticulously curated to foster an environment of peace, security, and absolute comfort for our residents.")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String?
  image     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model HeroContent {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  mediaUrl  String
  mediaType String   // "image" or "video"
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  status    String   @default("new") // new, read, replied, archived
  createdAt DateTime @default(now())
}